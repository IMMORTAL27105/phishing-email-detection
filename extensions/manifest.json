{
  "manifest_version": 3,
  "name": "Phish Confidence Tester",
  "version": "1.0",

  "permissions": ["scripting"],

  "host_permissions": [
    "https://mail.google.com/*",
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
